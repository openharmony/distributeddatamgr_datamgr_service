import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")

###############################################################################
# Unit test group - manages all unit test cases
###############################################################################

group("unittest") {
  testonly = true

  deps = [
    "bootstrap:unittests",
    "clone:unittests",
    "common:unittests",
    "data_share:DataHandlerTest",
    "permission:unittests",
    "value_proxy:unittests",
  ]

  if (datamgr_service_cloud) {
    deps += [ "cloud:unittests" ]
  }

  if (datamgr_service_data_share) {
    deps += [ "data_share:unittests" ]
  }

  if (datamgr_service_kvdb) {
    deps += [
      "backup:unittests",
      "kvdb:unittests",
      "upgrade:unittests",
    ]
  }

  if (datamgr_service_object) {
    deps += [ "object:unittests" ]
  }

  if (datamgr_service_rdb) {
    deps += [ "rdb:unittests" ]
  }

  if (datamgr_service_udmf) {
    deps += [
      "udmf:unittests",
      "utd:unittests",
    ]
  }
}
