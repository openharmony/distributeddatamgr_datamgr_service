import("//build/ohos_var.gni")
import("//build/test.gni")
import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")

module_output_path = "datamgr_service/datamgr_service/service/value_proxy"

###############################################################################
# value_proxy Unit Tests Definition
###############################################################################

ohos_unittest("ValueProxyServiceTest") {
  module_out_path = module_output_path
  sources = [
    "${data_service_path}/service/common/value_proxy.cpp",
    "value_proxy_test.cpp",
  ]

  configs = [ "//foundation/distributeddatamgr/datamgr_service/services/distributeddataservice/service/test:module_private_config" ]

  cflags = [
    "-fno-access-control",
    "-Wno-multichar",
    "-Wno-c99-designator",
  ]

  external_deps = [
    "ability_base:base",
    "ability_base:want",
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "kv_store:distributeddata_inner",
    "kv_store:distributeddb",
    "relational_store:native_rdb",
  ]

  deps = [
    "${data_service_path}/framework:distributeddatasvcfwk",
    "${data_service_path}/service:distributeddatasvc",
  ]
}

###############################################################################
# Cloud Test Collection Group
###############################################################################

group("unittests") {
  testonly = true
  deps = [
    ":ValueProxyServiceTest",
  ]
}