import("//build/config/features.gni")
import("//build/test.gni")
import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")

ohos_fuzztest("DataMiningEtlServiceStubFuzzTest") {
  module_out_path = "datamgr_service/datamgr_service"

  include_dirs = [
    "${data_mining_path}/include",
    "${datamgr_service_path}/services/data_mining_service/include",
    "${data_service_path}/framework/include",
  ]

  fuzz_config_file =
      "${data_service_path}/service/test/fuzztest/dataminingetlservicestub_fuzzer"

  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]

  sources = [ "dataminingetlservicestub_fuzzer.cpp" ]

  deps = [
    "${data_mining_path}:data_mining_client",
    "${datamgr_service_path}/services/data_mining_service:data_mining_etl_ipc",
    "${datamgr_service_path}/services/data_mining_service:data_mining_etl_runtime",
    "${data_service_path}/framework:distributeddatasvcfwk",
  ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_core",
    "json:nlohmann_json_static",
    "kv_store:datamgr_common",
  ]
}

group("fuzztest") {
  testonly = true

  deps = [ ":DataMiningEtlServiceStubFuzzTest" ]
}
