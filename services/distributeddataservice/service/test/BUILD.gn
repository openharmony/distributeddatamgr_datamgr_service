  if (datamgr_service_cloud) {
    deps += [ "unittest/cloud:unittests" ]
  }

  if (datamgr_service_udmf) {
    deps += [
      "unittest/udmf:unittests",
      "unittest/utd:unittests",
    ]
  }

  if (datamgr_service_object) {
    deps += [ "unittest/object:unittests" ]
  }

  if (datamgr_service_rdb) {
    deps += [
      ":RdbFlowControlManagerTest",
      ":RdbResultSetImplTest",
      ":RdbServiceImplTest",
      ":RdbServiceImplTokenTest",
      ":RdbServiceTest",
