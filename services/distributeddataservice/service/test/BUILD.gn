      # ":UpgradeMockTest",  # 已迁移到 unittest/bootstrap/BUILD.gn
      # ":UserDelegateMockTest",  # 已迁移到 unittest/permission/BUILD.gn
    ]
  }

  if (datamgr_service_data_share) {
    deps += [
      # ":DataShareServiceImplMockTest",  # TODO: To be migrated to data_share feature
      # ":DataShareServiceImplTest",  # TODO: To be migrated to data_share feature
    ]
