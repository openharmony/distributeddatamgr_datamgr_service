import("//build/test.gni")
import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")
module_output_path = "datamgr_service/datamgr_service/distributeddatafwk"

###############################################################################
config("module_private_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "${data_service_path}/framework/include",
    "${data_service_path}/adapter/include",
    "${data_service_path}/adapter/include/autils",
    "${data_service_path}/adapter/include/log",
    "${data_service_path}/adapter/include/permission",
    "${data_service_path}/adapter/include/utils",
    "${data_service_path}/adapter/test/mock",
    "..",
  ]

  cflags = [
    "-Werror",
    "-Werror=vla",
  ]
}

###############################################################################
ohos_unittest("ScreenLockTest") {
  module_out_path = module_output_path

  sources = [
    "screen_lock_test.cpp"
  ]

  configs = [ ":module_private_config" ]

  cflags = [
    "-fno-access-control",
    "-Werror=vla",
  ]

  deps = [
    "${data_service_path}/adapter/test:common_event_mock",
    "${data_service_path}/adapter/screenlock:distributeddata_screenlock",
    "${data_service_path}/framework:distributeddatasvcfwk"
  ]

  external_deps = [
    "ability_base:want",
    "c_utils:utils",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_core",
    "kv_store:datamgr_common",
  ]

  subsystem_name = "distributeddatamgr"
  part_name = "datamgr_service"
  defines = [ "OPENSSL_SUPPRESS_DEPRECATED" ]
}

###############################################################################
group("unittest") {
  testonly = true

  deps = []

  deps += [ ":ScreenLockTest" ]
}
###############################################################################
