import("//build/test.gni")
import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")

module_output_path = "datamgr_service/datamgr_service/distributeddatafwk"

ohos_unittest("BmsDelegateTest") {
  module_out_path = module_output_path

  sources = [
    "../bms_delegate_impl.cpp",
    "bms_delegate_test.cpp",
    "mock/samgr/iservice_registry.cpp",
  ]

  include_dirs = [
    "mock/samgr",
    "..",
    "${data_service_path}/framework/include",
    "${data_service_path}/framework/include/bms",
  ]

  cflags = [
    "-Dprivate=public",
    "-Dprotected=public",
    "-Werror",
    "-Werror=vla",
  ]

  deps = [ "${data_service_path}/framework:distributeddatasvcfwk" ]

  external_deps = [
    "bundle_framework:appexecfwk_base",
    "bundle_framework:appexecfwk_core",
    "c_utils:utils",
    "googletest:gmock",
    "googletest:gtest_main",
    "hilog:libhilog",
    "ipc:ipc_single",
    "kv_store:datamgr_common",
    "samgr:samgr_proxy",
  ]

  subsystem_name = "distributeddatamgr"
  part_name = "datamgr_service"
  defines = [ "OPENSSL_SUPPRESS_DEPRECATED" ]
}

group("unittest") {
  testonly = true
  deps = [ ":BmsDelegateTest" ]
}
