import("//build/ohos.gni")
import("//build/ohos_var.gni")
import("//build/test.gni")
import("//foundation/distributeddatamgr/datamgr_service/datamgr_service.gni")

module_output_path = "datamgr_service/datamgr_service/distributeddatafwk"

###############################################################################
config("module_private_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "${data_service_path}/framework/include",
    "${data_service_path}/framework/include/power_manager",
    "${data_service_path}/adapter/include",
    "${data_service_path}/adapter/include/autils",
    "${data_service_path}/adapter/include/log",
    "${data_service_path}/adapter/include/permission",
    "${data_service_path}/adapter/include/utils",
    "..",
  ]

  cflags = [
    "-Werror",
    "-Werror=vla",
  ]
}

###############################################################################
# PowerManagerDelegateTest - Test for Delegate class
ohos_unittest("PowerManagerDelegateTest") {
  module_out_path = module_output_path

  sources = [
    "power_manager_delegate_test.cpp",
  ]

  configs = [ ":module_private_config" ]

  cflags = [
    "-fno-access-control",
    "-Werror=vla",
  ]

  external_deps = [
    "ability_base:want",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "googletest:gtest_main",
    "hilog:libhilog",
    "kv_store:datamgr_common",
  ]

  deps = [
    "${data_service_path}/adapter/power_manager:distributeddata_power_manager",
    "${data_service_path}/framework:distributeddatasvcfwk",
  ]

  subsystem_name = "distributeddatamgr"
  part_name = "datamgr_service"
  defines = [ "OPENSSL_SUPPRESS_DEPRECATED" ]
}

###############################################################################
# PowerEventSubscriberTest - Test for PowerEventSubscriber class
ohos_unittest("PowerEventSubscriberTest") {
  module_out_path = module_output_path

  sources = [
    "power_event_subscriber_test.cpp",
  ]

  configs = [ ":module_private_config" ]

  cflags = [
    "-fno-access-control",
    "-Werror=vla",
  ]

  external_deps = [
    "ability_base:want",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "googletest:gtest_main",
    "hilog:libhilog",
    "kv_store:datamgr_common",
  ]

  deps = [
    "${data_service_path}/adapter/power_manager:distributeddata_power_manager",
    "${data_service_path}/framework:distributeddatasvcfwk",
  ]

  subsystem_name = "distributeddatamgr"
  part_name = "datamgr_service"
  defines = [ "OPENSSL_SUPPRESS_DEPRECATED" ]
}

###############################################################################
# PowerManagerImplTest - Test for PowerManagerImpl class
ohos_unittest("PowerManagerImplTest") {
  module_out_path = module_output_path

  sources = [
    "power_manager_impl_test.cpp",
  ]

  configs = [ ":module_private_config" ]

  cflags = [
    "-fno-access-control",
    "-Werror=vla",
  ]

  external_deps = [
    "ability_base:want",
    "c_utils:utils",
    "common_event_service:cesfwk_innerkits",
    "googletest:gtest_main",
    "hilog:libhilog",
    "kv_store:datamgr_common",
  ]

  deps = [
    "${data_service_path}/adapter/power_manager:distributeddata_power_manager",
    "${data_service_path}/framework:distributeddatasvcfwk",
  ]

  subsystem_name = "distributeddatamgr"
  part_name = "datamgr_service"
  defines = [ "OPENSSL_SUPPRESS_DEPRECATED" ]
}

###############################################################################
group("unittest") {
  testonly = true

  deps = [
    ":PowerManagerDelegateTest",
    ":PowerEventSubscriberTest",
    ":PowerManagerImplTest",
  ]
}
